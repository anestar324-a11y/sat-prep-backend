JWT_SECRET=ЭНИЙГ_ӨӨРЧИЛ_маш_нууц_түлхүүр_тавь

# ─── Сервер порт ───
PORT=5000

# ─── Frontend URL (CORS тохиргоо) ───
FRONTEND_URL=http://localhost:3000
